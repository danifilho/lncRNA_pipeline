configfile: "../config/config.yaml"

from pathlib import Path
import os
import re


SPECIES = config["species"]
PREFIX = config.get("prefix", SPECIES)
DOWNLOAD_SRA = bool(config.get("download_sra", False))


def fmt(value):
    if value is None:
        return None
    return str(value).format(species=SPECIES, prefix=PREFIX)


def cfg_path(name, default=None):
    return fmt(config.get(name, default))


def cfg_threads(name, default):
    return int(config.get("threads", {}).get(name, default))


def container(name):
    value = config.get("containers", {}).get(name)
    return fmt(value) if value else ""


def read_samples():
    configured = config.get("samples")
    if configured:
        return [str(sample).strip() for sample in configured if str(sample).strip()]

    sra_file = cfg_path("sra_accessions")
    if sra_file and os.path.exists(sra_file):
        with open(sra_file) as handle:
            return [line.strip() for line in handle if line.strip() and not line.startswith("#")]
    return []


SAMPLES = read_samples()

SRA_LIST = cfg_path("sra_accessions", "{species}/01_inputs/{species}_sra_IDs.txt")
RAW_DIR = cfg_path("raw_fastq_dir", "{species}/01_inputs/raw_fastq")
REFERENCE_FASTA = cfg_path("reference_fasta", "{species}/01_inputs/{species}.chromosomes.fa")
ANNOTATION_GTF = cfg_path("annotation_gtf", "{species}/01_inputs/{species}_mRNA.gtf")
STAR_INDEX_DIR = cfg_path("star_index_dir", "{species}/01_inputs/{prefix}_indexed")

FASTP_DIR = cfg_path("fastp_dir", "{species}/03_outputs/01_fastp")
STAR_DIR = cfg_path("star_dir", "{species}/03_outputs/02_STAR")
STRINGTIE_DIR = cfg_path("stringtie_dir", "{species}/03_outputs/03_stringtie")
GFFREAD_DIR = cfg_path("gffread_dir", "{species}/03_outputs/04_gffread")
FEELNC_DIR = cfg_path("feelnc_dir", "{species}/03_outputs/05_FEELnc")
CPAT_DIR = cfg_path("cpat_dir", "{species}/03_outputs/06_cpat")
LNCBOOST_DIR = cfg_path("lncboost_dir", "{species}/03_outputs/07_lncBoost")
LNCFINDER_DIR = cfg_path("lncfinder_dir", "{species}/03_outputs/08_lncFinder")
DIAMOND_DIR = cfg_path("diamond_dir", "{species}/03_outputs/09_diamond")
FINAL_DIR = cfg_path("final_dir", "{species}/03_outputs/10_final")
VERIFY_DIR = cfg_path("verify_dir", "{species}/03_outputs/11_verify")

ASSEMBLY_DIR = f"{STRINGTIE_DIR}/SRR_assemblies"
MERGED_GTF = f"{STRINGTIE_DIR}/{PREFIX}_denovo_trans.gtf"
CANDIDATE_GTF = f"{GFFREAD_DIR}/{PREFIX}_candidates.gtf"
CANDIDATE_FASTA = f"{GFFREAD_DIR}/{PREFIX}_candidates.fasta"
CANDIDATE_IDS = f"{GFFREAD_DIR}/{PREFIX}_candidates.txt"

FEELNC_GTF = f"{FEELNC_DIR}/{PREFIX}_FEELnc.gtf"
CPAT_OUTPUT = f"{CPAT_DIR}/{PREFIX}_cpat.output"
LNCBOOST_FEATURES = f"{LNCBOOST_DIR}/{PREFIX}_features.csv"
LNCBOOST_PREDICTIONS = f"{LNCBOOST_DIR}/{PREFIX}_predictions.txt"
LNCFINDER_STRUCTURES = f"{LNCFINDER_DIR}/folded_structures.txt"
LNCFINDER_RESULTS = f"{LNCFINDER_DIR}/{PREFIX}_lncFinder_wheat_model_results.csv"
DIAMOND_OUTPUT = f"{DIAMOND_DIR}/{PREFIX}_diamond_out.txt"

FINAL_IDS = f"{FINAL_DIR}/{PREFIX}_final_ids.txt"
INTERSECTION_SUMMARY = f"{FINAL_DIR}/{PREFIX}_intersection_summary.csv"
FINAL_GTF = f"{FINAL_DIR}/{PREFIX}_lncRNA.gtf"
FINAL_FASTA = f"{FINAL_DIR}/{PREFIX}_lncRNA.fasta"
FEELNC_CLASSES = f"{FINAL_DIR}/{PREFIX}_lncRNA_classes.txt"

DIAMOND_DB = cfg_path("diamond_db", "resources/uniprot/uniprot_out.dmnd")
UNIPROT_FASTA = cfg_path("uniprot_fasta", "resources/uniprot/uniprot_sprot.fasta")

TRUTH_INPUT_FASTA = cfg_path("truth_input_fasta", "truth_data/{species}/{prefix}_PLncDB_lncRNA.fa")
TRUTH_CLUSTERED_FASTA = cfg_path("truth_clustered_fasta", "truth_data/{species}/{prefix}_PLncDB_cd-hit.0.9.fa")
TRUTH_FASTA = TRUTH_CLUSTERED_FASTA if bool(config.get("cluster_truth", False)) else cfg_path("truth_fasta", "truth_data/{species}/{prefix}_PLncDB_cd-hit.0.9.fa")
VERIFY_PAF = f"{VERIFY_DIR}/{PREFIX}_truth_vs_pred.paf"
VERIFY_METRICS = f"{VERIFY_DIR}/{PREFIX}_truth_vs_pred.metrics.txt"


def raw_fastq_inputs(wildcards):
    sample = wildcards.sample
    candidates = [
        [f"{RAW_DIR}/{sample}_1.fastq.gz", f"{RAW_DIR}/{sample}_2.fastq.gz"],
        [f"{RAW_DIR}/{sample}_1.fastq"],
        [f"{RAW_DIR}/{sample}_1.fastq.gz"],
        [f"{RAW_DIR}/{sample}.fastq"],
        [f"{RAW_DIR}/{sample}.fastq.gz"],
    ]
    for files in candidates:
        if all(os.path.exists(path) for path in files):
            return files

    if DOWNLOAD_SRA:
        return f"{RAW_DIR}/.prefetch/{sample}.done"

    raise ValueError(
        f"Raw FASTQ files for sample '{sample}' were not found in {RAW_DIR}. "
        "Set download_sra: true or add files named sample_1/sample_2.fastq(.gz), "
        "sample_1.fastq(.gz), or sample.fastq(.gz)."
    )


def diamond_db_prefix(path):
    return re.sub(r"\.dmnd$", "", str(path))


primary_targets = [
    FINAL_IDS,
    INTERSECTION_SUMMARY,
    FINAL_GTF,
    FINAL_FASTA,
    FEELNC_CLASSES,
]

if bool(config.get("run_truth_alignment", False)):
    primary_targets.extend([VERIFY_PAF, VERIFY_METRICS])


rule all:
    input:
        primary_targets


rule prefetch_sra:
    output:
        done=f"{RAW_DIR}/.prefetch/{{sample}}.done"
    params:
        raw_dir=RAW_DIR
    threads:
        cfg_threads("prefetch", 8)
    container:
        container("sra_tools")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.raw_dir} {params.raw_dir}/.prefetch
        prefetch {wildcards.sample} --max-size 30G
        fasterq-dump {wildcards.sample} \
            --outdir {params.raw_dir} \
            --split-files \
            --skip-technical \
            --threads {threads} \
            --temp /tmp
        pigz -p {threads} -f {params.raw_dir}/{wildcards.sample}*.fastq
        touch {output.done}
        """


rule fastp:
    input:
        raw=raw_fastq_inputs
    output:
        done=f"{FASTP_DIR}/.done/{{sample}}.done",
        html=f"{FASTP_DIR}/{{sample}}_fastp.html",
        json=f"{FASTP_DIR}/{{sample}}_fastp.json"
    params:
        raw_dir=RAW_DIR,
        out_dir=FASTP_DIR
    threads:
        cfg_threads("fastp", 8)
    container:
        container("fastp")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.out_dir} {params.out_dir}/.done

        if [ -f "{params.raw_dir}/{wildcards.sample}_1.fastq.gz" ] && [ -f "{params.raw_dir}/{wildcards.sample}_2.fastq.gz" ]; then
            fastp \
              -i "{params.raw_dir}/{wildcards.sample}_1.fastq.gz" \
              -I "{params.raw_dir}/{wildcards.sample}_2.fastq.gz" \
              -o "{params.out_dir}/{wildcards.sample}_1_trim.fastq.gz" \
              -O "{params.out_dir}/{wildcards.sample}_2_trim.fastq.gz" \
              --detect_adapter_for_pe \
              --thread {threads} -x -g \
              --html {output.html} \
              --json {output.json}
        elif [ -f "{params.raw_dir}/{wildcards.sample}_1.fastq" ]; then
            fastp \
              -i "{params.raw_dir}/{wildcards.sample}_1.fastq" \
              -o "{params.out_dir}/{wildcards.sample}_trim.fastq.gz" \
              --thread {threads} -x -g \
              --html {output.html} \
              --json {output.json}
        elif [ -f "{params.raw_dir}/{wildcards.sample}_1.fastq.gz" ]; then
            fastp \
              -i "{params.raw_dir}/{wildcards.sample}_1.fastq.gz" \
              -o "{params.out_dir}/{wildcards.sample}_trim.fastq.gz" \
              --thread {threads} -x -g \
              --html {output.html} \
              --json {output.json}
        elif [ -f "{params.raw_dir}/{wildcards.sample}.fastq" ]; then
            fastp \
              -i "{params.raw_dir}/{wildcards.sample}.fastq" \
              -o "{params.out_dir}/{wildcards.sample}_trim.fastq.gz" \
              --thread {threads} -x -g \
              --html {output.html} \
              --json {output.json}
        elif [ -f "{params.raw_dir}/{wildcards.sample}.fastq.gz" ]; then
            fastp \
              -i "{params.raw_dir}/{wildcards.sample}.fastq.gz" \
              -o "{params.out_dir}/{wildcards.sample}_trim.fastq.gz" \
              --thread {threads} -x -g \
              --html {output.html} \
              --json {output.json}
        else
            echo "No raw FASTQ files found for {wildcards.sample} in {params.raw_dir}" >&2
            exit 1
        fi

        touch {output.done}
        """


rule star_genome_generate:
    input:
        fasta=REFERENCE_FASTA,
        annotation=ANNOTATION_GTF
    output:
        index=directory(STAR_INDEX_DIR)
    params:
        overhang=config.get("star_sjdb_overhang", 99),
        sa_index=config.get("star_genome_sa_index_nbases", 13)
    threads:
        cfg_threads("star_index", 8)
    container:
        container("star")
    shell:
        r"""
        set -euo pipefail
        rm -rf {output.index}
        mkdir -p {output.index}
        STAR \
          --runMode genomeGenerate \
          --runThreadN {threads} \
          --genomeDir {output.index} \
          --genomeFastaFiles {input.fasta} \
          --sjdbGTFfile {input.annotation} \
          --sjdbGTFtagExonParentTranscript transcript_id \
          --sjdbOverhang {params.overhang} \
          --genomeSAindexNbases {params.sa_index}
        """


rule star_align:
    input:
        fastp_done=f"{FASTP_DIR}/.done/{{sample}}.done",
        index=STAR_INDEX_DIR
    output:
        bam=f"{STAR_DIR}/{{sample}}_Aligned.sortedByCoord.out.bam"
    params:
        reads_dir=FASTP_DIR,
        out_dir=STAR_DIR
    threads:
        cfg_threads("star_align", 8)
    container:
        container("star")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.out_dir}

        if [ -f "{params.reads_dir}/{wildcards.sample}_1_trim.fastq.gz" ] && [ -f "{params.reads_dir}/{wildcards.sample}_2_trim.fastq.gz" ]; then
            READS="{params.reads_dir}/{wildcards.sample}_1_trim.fastq.gz {params.reads_dir}/{wildcards.sample}_2_trim.fastq.gz"
        elif [ -f "{params.reads_dir}/{wildcards.sample}_trim.fastq.gz" ]; then
            READS="{params.reads_dir}/{wildcards.sample}_trim.fastq.gz"
        else
            echo "No trimmed FASTQ files found for {wildcards.sample} in {params.reads_dir}" >&2
            exit 1
        fi

        STAR \
          --runThreadN {threads} \
          --genomeDir {input.index} \
          --readFilesIn $READS \
          --readFilesCommand zcat \
          --outFileNamePrefix {params.out_dir}/{wildcards.sample}_ \
          --outSAMtype BAM SortedByCoordinate \
          --outSAMattrIHstart 0 \
          --outSAMattributes NH HI AS nM NM \
          --outSAMstrandField intronMotif
        """


rule samtools_index:
    input:
        bam=f"{STAR_DIR}/{{sample}}_Aligned.sortedByCoord.out.bam"
    output:
        bai=f"{STAR_DIR}/{{sample}}_Aligned.sortedByCoord.out.bam.bai"
    threads:
        cfg_threads("samtools_index", 1)
    container:
        container("samtools")
    shell:
        "samtools index {input.bam}"


rule stringtie_assemble:
    input:
        bam=f"{STAR_DIR}/{{sample}}_Aligned.sortedByCoord.out.bam",
        bai=f"{STAR_DIR}/{{sample}}_Aligned.sortedByCoord.out.bam.bai",
        annotation=ANNOTATION_GTF
    output:
        gtf=f"{ASSEMBLY_DIR}/{{sample}}_assembled.gtf"
    params:
        min_len=config.get("stringtie_min_transcript_length", 200),
        min_junction=config.get("stringtie_min_junction_coverage", 2)
    threads:
        cfg_threads("stringtie_assemble", 8)
    container:
        container("stringtie")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {ASSEMBLY_DIR}
        stringtie \
          {input.bam} \
          -G {input.annotation} \
          -p {threads} \
          -m {params.min_len} \
          -j {params.min_junction} \
          -o {output.gtf}
        """


rule stringtie_merge:
    input:
        assemblies=expand(f"{ASSEMBLY_DIR}/{{sample}}_assembled.gtf", sample=SAMPLES),
        annotation=ANNOTATION_GTF
    output:
        gtf=MERGED_GTF
    params:
        min_len=config.get("stringtie_min_transcript_length", 200)
    threads:
        cfg_threads("stringtie_merge", 4)
    container:
        container("stringtie")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {STRINGTIE_DIR}
        if [ "{input.assemblies}" = "" ]; then
            echo "No StringTie assemblies were provided. Check sra_accessions or samples in config." >&2
            exit 1
        fi
        stringtie --merge \
          -G {input.annotation} \
          -m {params.min_len} \
          -o {output.gtf} \
          {input.assemblies}
        """


rule extract_candidates:
    input:
        gtf=MERGED_GTF,
        fasta=REFERENCE_FASTA
    output:
        gtf=CANDIDATE_GTF,
        fasta=CANDIDATE_FASTA,
        ids=CANDIDATE_IDS
    threads:
        cfg_threads("gffread", 2)
    container:
        container("gffread")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {GFFREAD_DIR}
        awk '/transcript_id "MSTRG/ {{print}}' {input.gtf} > {output.gtf}
        if [ ! -s {output.gtf} ]; then
            : > {output.fasta}
            : > {output.ids}
            exit 0
        fi
        gffread -w {output.fasta} -g {input.fasta} {output.gtf}
        grep '^>' {output.fasta} | sed 's/^>//' | sort -u > {output.ids}
        """


rule feelnc_filter:
    input:
        gtf=CANDIDATE_GTF,
        annotation=ANNOTATION_GTF
    output:
        gtf=FEELNC_GTF
    params:
        monoex=config.get("feelnc_monoex", -1),
        min_size=config.get("feelnc_min_size", 200)
    threads:
        cfg_threads("feelnc_filter", 20)
    container:
        container("feelnc")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {FEELNC_DIR}
        if [ ! -s {input.gtf} ]; then
            : > {output.gtf}
            exit 0
        fi
        FEELnc_filter.pl \
          -i {input.gtf} \
          -a {input.annotation} \
          --monoex={params.monoex} \
          -s {params.min_size} \
          -p {threads} > {output.gtf}
        """


rule cpat:
    input:
        fasta=CANDIDATE_FASTA,
        logit=cfg_path("cpat_logit", "scripts/Plant.logit.v2.RData")
    output:
        cpat=CPAT_OUTPUT
    params:
        hexamer=cfg_path("cpat_hexamer", "/opt/Plant-LncRNA-pipeline-v2/Model/Plant_Hexamer.tsv")
    threads:
        cfg_threads("cpat", 16)
    container:
        container("cpat")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {CPAT_DIR}
        if [ ! -s {input.fasta} ]; then
            printf 'seq_ID\tmRNA\tORF\tFickett\tHexamer\tcoding_prob\n' > {output.cpat}
            exit 0
        fi
        cpat.py \
          -x {params.hexamer} \
          -d {input.logit} \
          -g {input.fasta} \
          -o {output.cpat}
        """


rule lncboost:
    input:
        fasta=CANDIDATE_FASTA
    output:
        features=LNCBOOST_FEATURES,
        predictions=LNCBOOST_PREDICTIONS
    params:
        script_dir=cfg_path("plant_lncboost_script_dir", "/opt/Plant-LncRNA-pipeline-v2/PlantLncBoost/Script"),
        model=cfg_path("plant_lncboost_model", "/opt/Plant-LncRNA-pipeline-v2/Model/PlantLncBoost_model.cb"),
        threshold=config.get("lncboost_threshold", 0.5)
    threads:
        cfg_threads("lncboost", 20)
    container:
        container("lncboost")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {LNCBOOST_DIR}
        if [ ! -s {input.fasta} ]; then
            printf 'ID\tPredicted_label\tProbability\n' > {output.predictions}
            : > {output.features}
            exit 0
        fi
        python3 {params.script_dir}/Feature_extraction.py \
          -i {input.fasta} \
          -o {output.features}
        python3 {params.script_dir}/PlantLncBoost_prediction.py \
          -i {output.features} \
          -m {params.model} \
          -o {output.predictions} \
          -t {params.threshold}
        """


rule lncfinder:
    input:
        fasta=CANDIDATE_FASTA,
        runner="workflow/scripts/lncFinder.R"
    output:
        structures=LNCFINDER_STRUCTURES,
        results=LNCFINDER_RESULTS
    threads:
        cfg_threads("lncfinder", 32)
    container:
        container("lncfinder")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {LNCFINDER_DIR}
        if [ ! -s {input.fasta} ]; then
            printf '"ID","Pred"\n' > {output.results}
            : > {output.structures}
            exit 0
        fi
        RNAfold --noPS --jobs={threads} < {input.fasta} > {output.structures}
        Rscript {input.runner} \
          --input-fasta {input.fasta} \
          --fold-output {output.structures} \
          --output-csv {output.results} \
          --threads {threads}
        """


rule diamond_makedb:
    input:
        fasta=UNIPROT_FASTA
    output:
        db=DIAMOND_DB
    params:
        db_prefix=lambda wildcards, output: diamond_db_prefix(output.db)
    threads:
        cfg_threads("diamond", 32)
    container:
        container("diamond")
    shell:
        r"""
        set -euo pipefail
        mkdir -p $(dirname {output.db})
        diamond makedb --in {input.fasta} -d {params.db_prefix}
        """


rule diamond_blastx:
    input:
        fasta=CANDIDATE_FASTA,
        db=DIAMOND_DB
    output:
        out=DIAMOND_OUTPUT
    params:
        evalue=config.get("diamond_evalue", "1e-5")
    threads:
        cfg_threads("diamond", 32)
    container:
        container("diamond")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {DIAMOND_DIR}
        if [ ! -s {input.fasta} ]; then
            : > {output.out}
            exit 0
        fi
        diamond blastx \
          --threads {threads} \
          -d {input.db} \
          -q {input.fasta} \
          -o {output.out} \
          --outfmt 6 \
          --sensitive \
          --max-target-seqs 1 \
          --evalue {params.evalue}
        """


rule intersect_predictions:
    input:
        feelnc=FEELNC_GTF,
        cpat=CPAT_OUTPUT,
        boost=LNCBOOST_PREDICTIONS,
        lncfinder=LNCFINDER_RESULTS,
        diamond=DIAMOND_OUTPUT,
        script="workflow/scripts/intersect_ids.R"
    output:
        ids=FINAL_IDS,
        summary=INTERSECTION_SUMMARY
    params:
        out_prefix=f"{FINAL_DIR}/{PREFIX}",
        cpat_cutoff=config.get("cpat_coding_probability_cutoff", 0.46),
        diamond_evalue=config.get("diamond_evalue", "1e-5")
    threads:
        cfg_threads("intersect", 4)
    container:
        container("intersect")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {FINAL_DIR}
        Rscript {input.script} \
          --feelnc {input.feelnc} \
          --cpat {input.cpat} \
          --boost {input.boost} \
          --lncfinder {input.lncfinder} \
          --diamond {input.diamond} \
          --out {params.out_prefix} \
          --cpat-cutoff {params.cpat_cutoff} \
          --diamond-evalue {params.diamond_evalue}
        """


