rule feelnc_classifier:
    input:
        lnc_gtf=FINAL_GTF,
        annotation=ANNOTATION_GTF
    output:
        classes=FEELNC_CLASSES
    threads:
        4
    container:
        container("feelnc")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {FINAL_DIR}
        if [ ! -s {input.lnc_gtf} ]; then
            : > {output.classes}
            exit 0
        fi
        FEELnc_classifier.pl \
          -i {input.lnc_gtf} \
          -a {input.annotation} \
          -w 10000 \
          -m 100000 \
          -v 1 > {output.classes}
        """


rule truth_cdhit:
    input:
        fasta=TRUTH_INPUT_FASTA
    output:
        fasta=TRUTH_CLUSTERED_FASTA
    params:
        identity=config.get("cdhit_identity", 0.90)
    threads:
        cfg_threads("cdhit", 8)
    container:
        container("cd_hit")
    shell:
        r"""
        set -euo pipefail
        mkdir -p $(dirname {output.fasta})
        cd-hit \
          -i {input.fasta} \
          -o {output.fasta} \
          -c {params.identity} \
          -M 800 \
          -T {threads} \
          -l 200
        """


rule minimap2_truth_alignment:
    input:
        pred=FINAL_FASTA,
        truth=TRUTH_FASTA
    output:
        paf=VERIFY_PAF,
        metrics=VERIFY_METRICS
    params:
        identity=config.get("minimap_identity_cutoff", 0.95)
    threads:
        cfg_threads("minimap2", 8)
    container:
        container("minimap2")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {VERIFY_DIR}
        if [ ! -s {input.pred} ] || [ ! -s {input.truth} ]; then
            : > {output.paf}
            {
              echo "total_predicted_lncRNAs=0"
              echo "true_positive_predictions=0"
              echo "false_positive_predictions=0"
              echo "truth_sequences_hit=0"
              echo "total_truth_sequences=$(grep -c '^>' {input.truth} 2>/dev/null || echo 0)"
              echo "false_negative_truth_sequences=$(grep -c '^>' {input.truth} 2>/dev/null || echo 0)"
            } > {output.metrics}
            exit 0
        fi

        minimap2 -x cdna -t {threads} {input.truth} {input.pred} -o {output.paf}
        TOTAL_PRED=$(grep -c '^>' {input.pred})
        TP=$(awk -v cutoff="{params.identity}" '{{if($11 > 0 && $10/$11 > cutoff) print $1}}' {output.paf} | sort -u | wc -l | tr -d ' ')
        FP=$((TOTAL_PRED - TP))
        HIT_TRUTH=$(awk -v cutoff="{params.identity}" '{{if($11 > 0 && $10/$11 > cutoff) print $6}}' {output.paf} | sort -u | wc -l | tr -d ' ')
        TOTAL_TRUTH=$(grep -c '^>' {input.truth})
        FN=$((TOTAL_TRUTH - HIT_TRUTH))

        {
          echo "total_predicted_lncRNAs=${{TOTAL_PRED}}"
          echo "true_positive_predictions=${{TP}}"
          echo "false_positive_predictions=${{FP}}"
          echo "truth_sequences_hit=${{HIT_TRUTH}}"
          echo "total_truth_sequences=${{TOTAL_TRUTH}}"
          echo "false_negative_truth_sequences=${{FN}}"
        } > {output.metrics}
        """
