# IWGC lncRNA pipeline -- containerized re-implementation of
# Plant-LncRNA-pipeline-v2 (Tian et al.). Every step runs the same tool /
# command as the upstream pipeline; the only differences are Singularity
# containers + Snakemake orchestration.

configfile: "../config/config.yaml"

from pathlib import Path
import os
import re


SPECIES = config["species"]
PREFIX = config.get("prefix", SPECIES)
DOWNLOAD_SRA = bool(config.get("download_sra", False))
STRAND_SPECIFIC = bool(config.get("strand_specific", False))


def fmt(value):
    if value is None:
        return None
    return str(value).format(species=SPECIES, prefix=PREFIX)


def cfg_path(name, default=None):
    return fmt(config.get(name, default))


def cfg_threads(name, default):
    return int(config.get("threads", {}).get(name, default))


def container(name):
    value = config.get("containers", {}).get(name)
    return fmt(value) if value else ""


def read_samples():
    configured = config.get("samples")
    if configured:
        return [str(s).strip() for s in configured if str(s).strip()]
    sra_file = cfg_path("sra_accessions")
    if sra_file and os.path.exists(sra_file):
        with open(sra_file) as handle:
            return [l.strip() for l in handle if l.strip() and not l.startswith("#")]
    return []


SAMPLES = read_samples()

SRA_LIST = cfg_path("sra_accessions", "{species}/01_inputs/{species}_sra_IDs.txt")
RAW_DIR = cfg_path("raw_fastq_dir", "{species}/01_inputs/raw_fastq")
REFERENCE_FASTA = cfg_path("reference_fasta", "{species}/01_inputs/{species}.chromosomes.fa")
ANNOTATION_GTF = cfg_path("annotation_gtf", "{species}/01_inputs/{species}_mRNA.gtf")

HISAT2_INDEX_DIR = cfg_path("hisat2_index_dir", "{species}/01_inputs/{prefix}_hisat2_index")
HISAT2_INDEX_PREFIX = f"{HISAT2_INDEX_DIR}/{PREFIX}"

FASTP_DIR = cfg_path("fastp_dir", "{species}/03_outputs/01_fastp")
ALIGN_DIR = cfg_path("align_dir", "{species}/03_outputs/02_hisat2")
STRINGTIE_DIR = cfg_path("stringtie_dir", "{species}/03_outputs/03_stringtie")
GFFREAD_DIR = cfg_path("gffread_dir", "{species}/03_outputs/04_gffread")
FEELNC_DIR = cfg_path("feelnc_dir", "{species}/03_outputs/05_FEELnc")
CPAT_DIR = cfg_path("cpat_dir", "{species}/03_outputs/06_cpat")
LNCBOOST_DIR = cfg_path("lncboost_dir", "{species}/03_outputs/07_lncBoost")
LNCFINDER_DIR = cfg_path("lncfinder_dir", "{species}/03_outputs/08_lncFinder")
DIAMOND_DIR = cfg_path("diamond_dir", "{species}/03_outputs/09_diamond")
FINAL_DIR = cfg_path("final_dir", "{species}/03_outputs/10_final")

ASSEMBLY_DIR = f"{STRINGTIE_DIR}/SRR_assemblies"
MERGED_GTF = f"{STRINGTIE_DIR}/{PREFIX}_merge.gtf"
CANDIDATE_GTF = f"{GFFREAD_DIR}/candidate_transcript.gtf"
CANDIDATE_FASTA = f"{GFFREAD_DIR}/candidate_transcript.fasta"
CANDIDATE_IDS = f"{GFFREAD_DIR}/candidate_transcript.txt"

FEELNC_GTF = f"{FEELNC_DIR}/candidate_lncRNA.gtf"
FEELNC_CANDIDATE_TXT = f"{FEELNC_DIR}/candidate_lncRNA.txt"
CPAT_OUTPUT = f"{CPAT_DIR}/CPAT_plant.output"
LNCBOOST_FEATURES = f"{LNCBOOST_DIR}/PlantLncBoost_feature.csv"
LNCBOOST_PREDICTIONS = f"{LNCBOOST_DIR}/PlantLncBoost_prediction.csv"
LNCFINDER_RESULTS = f"{LNCFINDER_DIR}/plant-lncFinder.txt"
DIAMOND_OUTPUT = f"{DIAMOND_DIR}/uniprotoutput.txt"

FINAL_IDS = f"{FINAL_DIR}/Final_lncRNA_results.txt"
VENN_PDF = f"{FINAL_DIR}/Venn_pred_lncRNA.pdf"
FINAL_GTF = f"{FINAL_DIR}/lncRNA.gtf"
FINAL_FASTA = f"{FINAL_DIR}/lncRNA.fasta"
FEELNC_CLASSES = f"{FINAL_DIR}/lncRNA_classes.txt"

DIAMOND_DB = cfg_path("diamond_db", "resources/uniprot/uniprot_out.dmnd")
UNIPROT_FASTA = cfg_path("uniprot_fasta", "resources/uniprot/uniprot_sprot.fasta")

# Upstream model / script locations baked into the containers.
CPAT_HEXAMER = cfg_path("cpat_hexamer", "/opt/Plant-LncRNA-pipeline-v2/Model/Plant_Hexamer.tsv")
CPAT_LOGIT = cfg_path("cpat_logit", "/opt/Plant-LncRNA-pipeline-v2/Model/Plant.logit.RData")
LNCBOOST_SCRIPT_DIR = cfg_path("plant_lncboost_script_dir", "/opt/Plant-LncRNA-pipeline-v2/PlantLncBoost/Script")
LNCBOOST_MODEL = cfg_path("plant_lncboost_model", "/opt/Plant-LncRNA-pipeline-v2/Model/PlantLncBoost_model.cb")
INTERSECT_SCRIPT = cfg_path("intersect_script", "/opt/Plant-LncRNA-pipeline-v2/Script/prediction_insersection.sh")

RNA_STRANDNESS = "--rna-strandness RF" if STRAND_SPECIFIC else ""
STRINGTIE_RF = "--rf" if STRAND_SPECIFIC else ""


def raw_fastq_inputs(wildcards):
    sample = wildcards.sample
    candidates = [
        [f"{RAW_DIR}/{sample}_1.fastq.gz", f"{RAW_DIR}/{sample}_2.fastq.gz"],
        [f"{RAW_DIR}/{sample}_1.fastq", f"{RAW_DIR}/{sample}_2.fastq"],
        [f"{RAW_DIR}/{sample}.fastq.gz"],
        [f"{RAW_DIR}/{sample}.fastq"],
        [f"{RAW_DIR}/{sample}_1.fastq.gz"],
        [f"{RAW_DIR}/{sample}_1.fastq"],
    ]
    for files in candidates:
        if all(os.path.exists(p) for p in files):
            return files
    if DOWNLOAD_SRA:
        return f"{RAW_DIR}/.prefetch/{sample}.done"
    raise ValueError(
        f"Raw FASTQ for sample '{sample}' not found in {RAW_DIR}. "
        "Set download_sra: true or provide sample[_1/_2].fastq(.gz)."
    )


def diamond_db_prefix(path):
    return re.sub(r"\.dmnd$", "", str(path))


primary_targets = [FINAL_IDS, FINAL_GTF, FINAL_FASTA, FEELNC_CLASSES]


rule all:
    input:
        primary_targets


rule prefetch_sra:
    output:
        done=f"{RAW_DIR}/.prefetch/{{sample}}.done"
    params:
        raw_dir=RAW_DIR
    threads:
        cfg_threads("prefetch", 8)
    container:
        container("sra_tools")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.raw_dir} {params.raw_dir}/.prefetch
        # download the .sra into the (scratch) raw dir, never the cwd/home
        prefetch {wildcards.sample} --max-size 30G -O {params.raw_dir}/.prefetch
        fasterq-dump {params.raw_dir}/.prefetch/{wildcards.sample}/{wildcards.sample}.sra \
            --outdir {params.raw_dir} --split-files --skip-technical \
            --threads {threads} --temp {params.raw_dir}/.prefetch
        pigz -p {threads} -f {params.raw_dir}/{wildcards.sample}*.fastq
        rm -rf {params.raw_dir}/.prefetch/{wildcards.sample}
        touch {output.done}
        """


# 5.2 Data filtering / QC -- fastp (faithful: plain -i/-o)
rule fastp:
    input:
        raw=raw_fastq_inputs
    output:
        done=f"{FASTP_DIR}/.done/{{sample}}.done"
    params:
        raw_dir=RAW_DIR,
        out_dir=FASTP_DIR
    threads:
        cfg_threads("fastp", 8)
    container:
        container("fastp")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.out_dir} {params.out_dir}/.done
        R1PE_A="{params.raw_dir}/{wildcards.sample}_1.fastq.gz"
        R1PE_B="{params.raw_dir}/{wildcards.sample}_1.fastq"
        if {{ [ -f "$R1PE_A" ] || [ -f "$R1PE_B" ]; }} && \
           {{ [ -f "{params.raw_dir}/{wildcards.sample}_2.fastq.gz" ] || [ -f "{params.raw_dir}/{wildcards.sample}_2.fastq" ]; }}; then
            R1=$([ -f "$R1PE_A" ] && echo "$R1PE_A" || echo "$R1PE_B")
            R2=$([ -f "{params.raw_dir}/{wildcards.sample}_2.fastq.gz" ] && echo "{params.raw_dir}/{wildcards.sample}_2.fastq.gz" || echo "{params.raw_dir}/{wildcards.sample}_2.fastq")
            fastp -i "$R1" -I "$R2" \
              -o "{params.out_dir}/{wildcards.sample}_1_clean.fastq.gz" \
              -O "{params.out_dir}/{wildcards.sample}_2_clean.fastq.gz" \
              --thread {threads}
        else
            if [ -f "{params.raw_dir}/{wildcards.sample}.fastq.gz" ]; then R1="{params.raw_dir}/{wildcards.sample}.fastq.gz";
            elif [ -f "{params.raw_dir}/{wildcards.sample}.fastq" ]; then R1="{params.raw_dir}/{wildcards.sample}.fastq";
            elif [ -f "$R1PE_A" ]; then R1="$R1PE_A";
            else R1="$R1PE_B"; fi
            fastp -i "$R1" -o "{params.out_dir}/{wildcards.sample}_clean.fastq.gz" --thread {threads}
        fi
        touch {output.done}
        """


# 6. HISAT2 reference index
rule hisat2_index:
    input:
        fasta=REFERENCE_FASTA
    output:
        done=f"{HISAT2_INDEX_DIR}/.index.done"
    params:
        prefix=HISAT2_INDEX_PREFIX,
        index_dir=HISAT2_INDEX_DIR
    threads:
        cfg_threads("hisat2_index", 8)
    container:
        container("hisat2")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.index_dir}
        hisat2-build -p {threads} {input.fasta} {params.prefix}
        touch {output.done}
        """


# 6. HISAT2 alignment -> sorted BAM (hisat2 | samtools sort, one container)
rule hisat2_align:
    input:
        fastp_done=f"{FASTP_DIR}/.done/{{sample}}.done",
        index_done=f"{HISAT2_INDEX_DIR}/.index.done"
    output:
        bam=f"{ALIGN_DIR}/{{sample}}.bam"
    params:
        prefix=HISAT2_INDEX_PREFIX,
        reads_dir=FASTP_DIR,
        out_dir=ALIGN_DIR,
        strandness=RNA_STRANDNESS
    threads:
        cfg_threads("hisat2_align", 10)
    container:
        container("hisat2")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.out_dir}
        if [ -f "{params.reads_dir}/{wildcards.sample}_1_clean.fastq.gz" ]; then
            READS="-1 {params.reads_dir}/{wildcards.sample}_1_clean.fastq.gz -2 {params.reads_dir}/{wildcards.sample}_2_clean.fastq.gz"
        else
            READS="-U {params.reads_dir}/{wildcards.sample}_clean.fastq.gz"
        fi
        hisat2 --new-summary {params.strandness} -p {threads} \
            -x {params.prefix} $READS \
          | samtools sort -@ {threads} -o {output.bam} -
        """


# 7. StringTie per-sample assembly
rule stringtie_assemble:
    input:
        bam=f"{ALIGN_DIR}/{{sample}}.bam",
        annotation=ANNOTATION_GTF
    output:
        gtf=f"{ASSEMBLY_DIR}/{{sample}}.gtf"
    params:
        rf=STRINGTIE_RF
    threads:
        cfg_threads("stringtie_assemble", 10)
    container:
        container("stringtie")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {ASSEMBLY_DIR}
        stringtie -p {threads} {params.rf} -G {input.annotation} -o {output.gtf} {input.bam}
        """


# 7. StringTie merge + candidate extraction
rule stringtie_merge:
    input:
        assemblies=expand(f"{ASSEMBLY_DIR}/{{sample}}.gtf", sample=SAMPLES),
        annotation=ANNOTATION_GTF
    output:
        gtf=MERGED_GTF
    threads:
        cfg_threads("stringtie_merge", 4)
    container:
        container("stringtie")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {STRINGTIE_DIR}
        stringtie --merge -G {input.annotation} -o {output.gtf} {input.assemblies}
        """


rule extract_candidates:
    input:
        gtf=MERGED_GTF,
        fasta=REFERENCE_FASTA
    output:
        gtf=CANDIDATE_GTF,
        fasta=CANDIDATE_FASTA,
        ids=CANDIDATE_IDS
    threads:
        cfg_threads("gffread", 2)
    container:
        container("gffread")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {GFFREAD_DIR}
        grep 'transcript_id "MSTRG' {input.gtf} > {output.gtf} || true
        if [ ! -s {output.gtf} ]; then : > {output.fasta}; : > {output.ids}; exit 0; fi
        gffread -w {output.fasta} -g {input.fasta} {output.gtf}
        grep '>' {output.fasta} | awk '{{print $1}}' | sed 's/>//g' | sort -u > {output.ids}
        """


# 8.1 FEELnc filter (remove < 200 bp / overlapping mRNA) + ID list
rule feelnc_filter:
    input:
        gtf=CANDIDATE_GTF,
        annotation=ANNOTATION_GTF
    output:
        gtf=FEELNC_GTF,
        ids=FEELNC_CANDIDATE_TXT
    threads:
        cfg_threads("feelnc_filter", 20)
    container:
        container("feelnc")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {FEELNC_DIR}
        if [ ! -s {input.gtf} ]; then : > {output.gtf}; : > {output.ids}; exit 0; fi
        FEELnc_filter.pl -i {input.gtf} -a {input.annotation} --monoex=-1 -s 200 -p {threads} > {output.gtf}
        cut -d ";" -f 2 {output.gtf} | sed 's/ transcript_id //g' | sed 's/"//g' | sort -u > {output.ids}
        """


# 8.4 CPAT-plant (Plant_Hexamer + Plant.logit.RData)
rule cpat:
    input:
        fasta=CANDIDATE_FASTA
    output:
        cpat=CPAT_OUTPUT
    params:
        hexamer=CPAT_HEXAMER,
        logit=CPAT_LOGIT
    threads:
        cfg_threads("cpat", 8)
    container:
        container("cpat")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {CPAT_DIR}
        if [ ! -s {input.fasta} ]; then printf 'mRNA_size\tORF_size\tFickett_score\tHexamer_score\tcoding_prob\n' > {output.cpat}; exit 0; fi
        cpat.py -x {params.hexamer} -d {params.logit} -g {input.fasta} -o {output.cpat}
        """


# 8.3 LncFinder-plant (make_frequencies + Plant_model.rda, SS.features = FALSE)
rule lncfinder:
    input:
        fasta=CANDIDATE_FASTA,
        runner="workflow/scripts/lncFinder.R"
    output:
        results=LNCFINDER_RESULTS
    threads:
        cfg_threads("lncfinder", 8)
    container:
        container("lncfinder")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {LNCFINDER_DIR}
        Rscript {input.runner} --input-fasta {input.fasta} --output-txt {output.results} --threads {threads}
        """


# 8.2 PlantLncBoost
rule lncboost:
    input:
        fasta=CANDIDATE_FASTA
    output:
        features=LNCBOOST_FEATURES,
        predictions=LNCBOOST_PREDICTIONS
    params:
        script_dir=LNCBOOST_SCRIPT_DIR,
        model=LNCBOOST_MODEL
    threads:
        cfg_threads("lncboost", 8)
    container:
        container("lncboost")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {LNCBOOST_DIR}
        if [ ! -s {input.fasta} ]; then printf 'id\tPredicted_label\n' > {output.predictions}; : > {output.features}; exit 0; fi
        python3 {params.script_dir}/Feature_extraction.py -i {input.fasta} -o {output.features}
        python3 {params.script_dir}/PlantLncBoost_prediction.py -i {output.features} -m {params.model} -t 0.5 -o {output.predictions}
        """


# 8.5 DIAMOND vs UniProt (plain blastx, faithful)
rule diamond_makedb:
    input:
        fasta=UNIPROT_FASTA
    output:
        db=DIAMOND_DB
    params:
        db_prefix=lambda wildcards, output: diamond_db_prefix(output.db)
    threads:
        cfg_threads("diamond", 16)
    container:
        container("diamond")
    shell:
        r"""
        set -euo pipefail
        mkdir -p $(dirname {output.db})
        diamond makedb --in {input.fasta} -d {params.db_prefix}
        """


rule diamond_blastx:
    input:
        fasta=CANDIDATE_FASTA,
        db=DIAMOND_DB
    output:
        out=DIAMOND_OUTPUT
    threads:
        cfg_threads("diamond", 16)
    container:
        container("diamond")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {DIAMOND_DIR}
        if [ ! -s {input.fasta} ]; then : > {output.out}; exit 0; fi
        diamond blastx -d {input.db} -q {input.fasta} -o {output.out}
        """


# 8.6 Intersection -> high-confidence lncRNAs (upstream prediction_insersection.sh)
rule intersect_predictions:
    input:
        feelnc=FEELNC_CANDIDATE_TXT,
        boost=LNCBOOST_PREDICTIONS,
        cpat=CPAT_OUTPUT,
        lncfinder=LNCFINDER_RESULTS,
        diamond=DIAMOND_OUTPUT,
        script="workflow/scripts/prediction_insersection.sh"
    output:
        ids=FINAL_IDS,
        venn=VENN_PDF
    params:
        script=INTERSECT_SCRIPT,
        final_dir=FINAL_DIR
    threads:
        cfg_threads("intersect", 4)
    container:
        container("intersect")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.final_dir}
        feelnc=$(readlink -f {input.feelnc}); boost=$(readlink -f {input.boost})
        cpat=$(readlink -f {input.cpat}); lncf=$(readlink -f {input.lncfinder})
        diam=$(readlink -f {input.diamond}); script=$(readlink -f {input.script})
        cd {params.final_dir}
        Rscript "$script" "$feelnc" "$boost" "$cpat" "$lncf" "$diam"
        """


# lncRNA GTF (grep -Fwf, faithful)
rule final_lncRNA_gtf:
    input:
        ids=FINAL_IDS,
        gtf=CANDIDATE_GTF
    output:
        gtf=FINAL_GTF
    container:
        container("gffread")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {FINAL_DIR}
        if [ ! -s {input.ids} ]; then : > {output.gtf}; exit 0; fi
        grep -Fwf {input.ids} {input.gtf} > {output.gtf} || true
        """


# lncRNA FASTA (convenience extract from the faithful GTF)
rule final_lncRNA_fasta:
    input:
        gtf=FINAL_GTF,
        fasta=REFERENCE_FASTA
    output:
        fasta=FINAL_FASTA
    threads:
        cfg_threads("gffread", 2)
    container:
        container("gffread")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {FINAL_DIR}
        if [ ! -s {input.gtf} ]; then : > {output.fasta}; exit 0; fi
        gffread -w {output.fasta} -g {input.fasta} {input.gtf}
        """


# 9. Classification by genomic location + category breakdown (faithful awk filters)
rule feelnc_classifier:
    input:
        lnc_gtf=FINAL_GTF,
        annotation=ANNOTATION_GTF
    output:
        classes=FEELNC_CLASSES
    threads:
        4
    container:
        container("feelnc")
    shell:
        r"""
        set -euo pipefail
        mkdir -p {FINAL_DIR}
        if [ ! -s {input.lnc_gtf} ]; then : > {output.classes}; exit 0; fi
        FEELnc_classifier.pl -i {input.lnc_gtf} -a {input.annotation} > {output.classes}
        cd {FINAL_DIR}
        cls=$(basename {output.classes})
        awk -F '\t' '{{if($1==1 && $6=="antisense" && $10=="exonic"){{print $0}}}}' "$cls" > LncRNA_antisense_exonic.txt || true
        awk -F '\t' '{{if($1==1 && $6=="sense" && $10=="intronic"){{print $0}}}}' "$cls" > LncRNA_intronic.txt || true
        awk -F '\t' '{{if($1==1 && $6=="sense" && $7=="intergenic" && $8<=2000 && $10=="upstream"){{print $0}}}}' "$cls" > LncRNA_upstream.txt || true
        awk -F '\t' '{{if($1==1 && $6=="sense" && $7=="intergenic" && $8<=2000 && $10=="downstream"){{print $0}}}}' "$cls" > LncRNA_downstream.txt || true
        awk -F '\t' '{{if($1==1 && $7=="intergenic" && $8>2000){{print $0}}}}' "$cls" > LncRNA_intergenic.txt || true
        awk -F '\t' '{{if($1==1 && $6=="antisense" && $7=="intergenic" && $8<=2000 && $10=="upstream"){{print $0}}}}' "$cls" > LncRNA_Bidirectional.txt || true
        """
