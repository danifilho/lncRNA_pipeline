Bootstrap: docker
From: ubuntu:22.04

%files
    # Source (local) -> Destination (inside container)
    intersect_ids.R /usr/local/bin/intersect_ids.R

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        r-base \
        r-cran-tidyverse \
        r-cran-optparse \
        libcurl4-openssl-dev \
        libxml2-dev \
        libssl-dev

    # Ensure the script is executable inside the container
    chmod 755 /usr/local/bin/intersect_ids.R
    
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%runscript
    exec Rscript /usr/local/bin/intersect_ids.R "$@"

%help
    LncRNA Intersection Tool (Memory Optimized)
