Bootstrap: docker
From: ubuntu:22.04

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y \
        build-essential \
        perl \
        python3 \
        wget \
        curl \
        unzip \
        cpanminus \
        libxml2-dev \
        libssl-dev \
        zlib1g-dev \
        libdb-dev \
        libexpat1-dev \
        libxml-parser-perl \
        libxml-dom-perl \
        libxml-twig-perl \
        libmodule-build-perl \
        bioperl \
        libbio-db-seqfeature-perl  # <--- THIS IS THE MISSING PIECE

    # Re-run the CPAN installs to make sure everything is linked
    cpanm --force XML::Parser XML::DOM XML::Twig
    cpanm Bio::Root::Version Bio::DB::Fasta Parallel::ForkManager \
          Getopt::Long Set::IntervalTree LWP::UserAgent \
          Bio::SeqFeature::Lite

%environment
    export LC_ALL=C