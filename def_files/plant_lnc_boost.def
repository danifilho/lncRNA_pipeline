Bootstrap: docker
From: python:3.9-slim

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y \
        build-essential \
        libgomp1 \
        wget \
        curl \
        && apt-get clean

    # 1. Upgrade pip
    pip install --no-cache-dir --upgrade pip

    # 2. Install the Science & ML Stack
    # libgomp1 is included above to ensure CatBoost doesn't crash on multi-threading
    pip install --no-cache-dir \
        numpy \
        pandas \
        scipy \
        biopython \
        catboost \
        scikit-learn

%environment
    # Ensure Python can find all libraries and handles character encoding
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%labels
    Maintainer Gemini_AI
    Version 2.0
    Description "Python Engine for PlantLncBoost (CatBoost, Biopython, Scipy)"
