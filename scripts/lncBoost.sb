#!/bin/bash --login
#SBATCH --job-name=species_lncBoost
#SBATCH --cpus-per-task=20
#SBATCH --mem=64G
#SBATCH --time=05:00:00
#SBATCH --output=/mnt/scratch/lemasjoh/BASF/logs/%x_%j.out

# --- Paths ---
IMAGE="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/def_files/plant_lnc_boost.sif" # dedicated image for this step
SCRIPT_DIR="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/scripts/Plant-LncRNA-pipeline-v2/PlantLncBoost/Script" # contains both Feature_extraction.py and PlantLncBoost_prediction.py
MODEL="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/scripts/Plant-LncRNA-pipeline-v2/Model/PlantLncBoost_model.cb" # pre-trained model for plant lncRNA prediction

INPUT_FASTA="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/species/03_outputs/04_gffread/species_candidates.fasta" # input fasta file containing candidate lncRNA sequences
OUT_DIR="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/species/03_outputs/07_lncBoost"
FEATURE_CSV="${OUT_DIR}/species_features.csv"
FINAL_RESULTS="${OUT_DIR}/species_predictions.txt"

# --- STEP 1: Feature Extraction ---
echo "Starting Feature Extraction..."
singularity exec -B /mnt/scratch/lemasjoh $IMAGE \
    python3 ${SCRIPT_DIR}/Feature_extraction.py -i $INPUT_FASTA -o $FEATURE_CSV

# --- STEP 2: Prediction ---
echo "...feature extraction complete.\nStarting Prediction..."
singularity exec -B /mnt/scratch/lemasjoh $IMAGE \
    python3 ${SCRIPT_DIR}/PlantLncBoost_prediction.py \
    -i $FEATURE_CSV \
    -m $MODEL \
    -o $FINAL_RESULTS \
    -t 0.5

echo "Pipeline complete. Results are in $FINAL_RESULTS"