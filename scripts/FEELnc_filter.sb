#!/bin/bash --login
#SBATCH --job-name=species_feelnc_filter
#SBATCH --cpus-per-task=20
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH --output=/mnt/scratch/lemasjoh/BASF/logs/%x_%j.out

# 1. Paths
IMAGE="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/def_files/FEELnc.sif"
INPUT_GTF="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/species/03_outputs/03_stringtie/species_candidates.gtf"
REF_ANN="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/species/01_inputs/species_mRNA.gtf"
OUTPUT_DIR="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/species/03_outputs/05_FEELnc"
OUTPUT_GTF="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/species/03_outputs/05_FEELnc/species_FEELnc.gtf"
FEELNC_DIR="/mnt/scratch/lemasjoh/BASF/IWGC_lncRNA_pipeline/scripts/feelnc"

mkdir -p $OUTPUT_DIR

# 2. Run it
singularity exec -B /mnt/scratch/lemasjoh $IMAGE \
    env PERL5LIB="${FEELNC_DIR}/lib" \
    perl ${FEELNC_DIR}/scripts/FEELnc_filter.pl \
    -i $INPUT_GTF \
    -a $REF_ANN \
    --monoex=-1 -s 200 -p 20 > $OUTPUT_GTF

echo "FEELnc filtering complete."